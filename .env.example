# Supabase Postgres
# Pooled connection (use this for runtime queries)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres"
# Direct connection (use this for drizzle-kit migrations)
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Single-user password gate (any non-empty value)
APP_PASSWORD="change-me"

# v2 (not yet wired)
RESEND_API_KEY=""
CRON_SECRET=""
